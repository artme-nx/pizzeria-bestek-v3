{
  "$schema": "https://design-tokens.org/schema.json",
  "primitive": {
    "color": {
      "char": {
        "950": { "$value": "#120E0B", "$type": "color" },
        "900": { "$value": "#1B1512", "$type": "color" },
        "800": { "$value": "#2A211B", "$type": "color" },
        "700": { "$value": "#3F332A", "$type": "color" }
      },
      "bone": {
        "100": { "$value": "#F5EFE2", "$type": "color" },
        "300": { "$value": "#DFCFB2", "$type": "color" },
        "500": { "$value": "#A5947C", "$type": "color" }
      },
      "steel": {
        "400": { "$value": "#9FBAC4", "$type": "color" },
        "500": { "$value": "#5C8494", "$type": "color" },
        "700": { "$value": "#37596A", "$type": "color" },
        "900": { "$value": "#182E38", "$type": "color" }
      },
      "copper": {
        "400": { "$value": "#DE9662", "$type": "color" },
        "500": { "$value": "#C3743F", "$type": "color" },
        "700": { "$value": "#8B4F29", "$type": "color" }
      }
    },
    "font": {
      "display": { "$value": "var(--font-bricolage), 'Bricolage Grotesque', system-ui, sans-serif", "$type": "fontFamily" },
      "sans": { "$value": "var(--font-instrument-sans), 'Instrument Sans', system-ui, sans-serif", "$type": "fontFamily" }
    },
    "motion": {
      "duration": {
        "micro": { "$value": "180ms", "$type": "duration" },
        "base": { "$value": "320ms", "$type": "duration" },
        "reveal": { "$value": "1.1s", "$type": "duration" },
        "cine": { "$value": "1.8s", "$type": "duration" }
      },
      "ease": {
        "out-expo": { "$value": "cubic-bezier(0.16, 1, 0.3, 1)", "$type": "cubicBezier" },
        "cine": { "$value": "cubic-bezier(0.65, 0, 0.35, 1)", "$type": "cubicBezier" }
      }
    },
    "tracking": {
      "display": { "$value": "-0.01em", "$type": "dimension" },
      "label": { "$value": "0.28em", "$type": "dimension" }
    }
  },
  "semantic": {
    "background": { "$value": "{primitive.color.char.950}", "$type": "color" },
    "foreground": { "$value": "{primitive.color.bone.100}", "$type": "color" },
    "card": { "$value": "{primitive.color.char.900}", "$type": "color" },
    "card-foreground": { "$value": "{primitive.color.bone.100}", "$type": "color" },
    "muted": { "$value": "{primitive.color.char.900}", "$type": "color" },
    "muted-foreground": { "$value": "{primitive.color.bone.500}", "$type": "color" },
    "accent": { "$value": "{primitive.color.char.800}", "$type": "color" },
    "accent-foreground": { "$value": "{primitive.color.bone.100}", "$type": "color" },
    "border": { "$value": "{primitive.color.char.700}", "$type": "color" },
    "ring": { "$value": "{primitive.color.steel.500}", "$type": "color" },
    "radius": { "$value": "0.65rem", "$type": "dimension" },
    "steel": { "$value": "{primitive.color.steel.400}", "$type": "color" },
    "steel-dim": { "$value": "{primitive.color.steel.900}", "$type": "color" },
    "copper": { "$value": "{primitive.color.copper.500}", "$type": "color" },
    "surface-line": { "$value": "{primitive.color.char.700}", "$type": "color" },
    "type-display": { "$value": "{primitive.font.display}", "$type": "fontFamily" },
    "type-body": { "$value": "{primitive.font.sans}", "$type": "fontFamily" },
    "ease-reveal": { "$value": "{primitive.motion.ease.out-expo}", "$type": "cubicBezier" },
    "ease-cine": { "$value": "{primitive.motion.ease.cine}", "$type": "cubicBezier" },
    "duration-micro": { "$value": "{primitive.motion.duration.micro}", "$type": "duration" },
    "duration-base": { "$value": "{primitive.motion.duration.base}", "$type": "duration" },
    "duration-reveal": { "$value": "{primitive.motion.duration.reveal}", "$type": "duration" },
    "tracking-display": { "$value": "{primitive.tracking.display}", "$type": "dimension" },
    "tracking-label": { "$value": "{primitive.tracking.label}", "$type": "dimension" }
  },
  "component": {
    "hero": {
      "title-size": { "$value": "clamp(2.6rem, 7vw, 5.8rem)", "$type": "dimension" },
      "title-leading": { "$value": "1.03", "$type": "number" },
      "glow": {
        "$value": "radial-gradient(ellipse 65% 50% at 50% 100%, rgba(195, 116, 63, 0.22), rgba(24, 46, 56, 0.12) 45%, transparent 72%)",
        "$type": "gradient"
      },
      "vignette": {
        "$value": "linear-gradient(to top, rgba(18, 14, 11, 0.96) 0%, rgba(18, 14, 11, 0.32) 42%, rgba(18, 14, 11, 0.6) 100%)",
        "$type": "gradient"
      }
    },
    "button": {
      "primary-bg": { "$value": "{primitive.color.steel.500}", "$type": "color" },
      "primary-fg": { "$value": "{primitive.color.char.950}", "$type": "color" },
      "primary-hover-bg": { "$value": "{primitive.color.bone.100}", "$type": "color" },
      "ghost-border": { "$value": "rgba(245, 239, 226, 0.35)", "$type": "color" },
      "ghost-hover-border": { "$value": "{primitive.color.steel.500}", "$type": "color" }
    }
  }
}
